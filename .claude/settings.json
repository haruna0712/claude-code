{
  "permissions": {
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm -fr *)",
      "Bash(rm -Rf *)",
      "Bash(rm -rF *)",
      "Bash(rm -r -f *)",
      "Bash(rm -f -r *)",
      "Bash(rm --recursive --force *)",
      "Bash(rm --force --recursive *)",
      "Bash(sudo rm *)",

      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Bash(cat .env*)",
      "Bash(cat ./.env*)",
      "Bash(cat *.env*)",
      "Bash(head .env*)",
      "Bash(tail .env*)",
      "Bash(less .env*)",
      "Bash(more .env*)",
      "Bash(xxd .env*)",
      "Bash(od .env*)",

      "Read(**/.ssh/**)",
      "Read(**/id_rsa)",
      "Read(**/id_rsa.*)",
      "Read(**/id_ed25519)",
      "Read(**/id_ed25519.*)",
      "Read(**/id_ecdsa)",
      "Read(**/id_ecdsa.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.pfx)",
      "Read(**/*.p12)",

      "Read(**/.aws/credentials)",
      "Read(**/.aws/config)",
      "Read(**/.config/gcloud/**)",
      "Read(**/application_default_credentials.json)",
      "Read(**/.kube/config)",
      "Read(**/.azure/**)",

      "Read(**/.netrc)",
      "Read(**/_netrc)",
      "Read(**/.npmrc)",
      "Read(**/.pypirc)",
      "Read(**/.docker/config.json)",
      "Read(**/.gnupg/**)",
      "Read(**/secrets.*)",
      "Read(**/*.secret)",
      "Read(**/*credentials*.json)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.devcontainer/hooks/block-mnt-mount.sh\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.devcontainer/hooks/block-mnt-in-compose.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "for t in /dev/pts/[0-9]*; do [ -w \"$t\" ] && printf '\\a' > \"$t\"; done; true"
          },
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/scripts/export-claude-session.py\" --quiet >/dev/null 2>&1 || true"
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "for t in /dev/pts/[0-9]*; do [ -w \"$t\" ] && printf '\\a' > \"$t\"; done; true"
          }
        ]
      }
    ]
  }
}
